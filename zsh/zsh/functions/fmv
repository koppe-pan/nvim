# Move multiple files to directory with FZF
fmv() {
    local obj
    local dir
    obj=$(find ${1:-.} -path '*/\.*' -prune \
                    -o -type f -print 2> /dev/null | fzf -m) &&
    dir=$(find ${1:-.} -path '*/\.*' -prune \
                    -o -type d -print 2> /dev/null | fzf +m) &&
    for f in "$obj"; do
      mv "$f" "$dir"
    done
}
